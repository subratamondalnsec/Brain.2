      ]
    },
    {
      "name": "Chat — Upload Mode",
      "description": "Endpoints used when the user is actively sending memories into Second Brain (text, image entries). All routes protected via JWT.",
      "item": [
        {
          "name": "Add Text Entry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "description": "Save a text memory entry for today's date. The text is pushed to the RAG vector store and saved to MongoDB. Returns 201 on success.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Had a productive meeting with the team about the Second Brain architecture. Decided to go with RAG + Groq for real-time querying.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/chat/entry/text",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "entry", "text"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Entry saved', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Add Image Entry",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Upload an image + optional caption as a memory entry. Image is uploaded to Cloudinary via file.tempFilePath. The Cloudinary URL is stored in MongoDB. Returns 201 on success.",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Image to store as memory entry (.jpg, .png etc.)"
                },
                {
                  "key": "caption",
                  "value": "Screenshot of the project architecture planning board",
                  "type": "text",
                  "description": "Optional caption describing the image context"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/chat/entry/image",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "entry", "image"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "pm.test('Image entry saved', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Chat History (date list)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Returns all unique dates that have chat entries for the current user, sorted newest first. Used by StorageHistory.jsx to populate the date filter.",
            "url": {
              "raw": "{{base_url}}/api/chat/history",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "history"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has history array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('history');",
                  "    pm.expect(json.history).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Chat By Date",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Fetch all memory entries (text, image, audio, document) for a specific date. Replace the date segment in the URL with any YYYY-MM-DD date.",
            "url": {
              "raw": "{{base_url}}/api/chat/{{today}}",
              "host": ["{{base_url}}"],
              "path": ["api", "chat", "{{today}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has entries array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('entries');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Query Mode",
      "description": "RAG-powered natural language querying over the user's personal memory store. All queries go through the vector search pipeline.",
      "item": [
        {
          "name": "Send Query",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" },
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "description": "Ask a natural language question across the user's entire memory store. The backend performs a RAG vector search and returns a synthesized AI response. Body field: { query: string }.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"What did I discuss about the project architecture last week?\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/query",
              "host": ["{{base_url}}"],
              "path": ["api", "query"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has response field', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('response');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Analytics — Ambient AI",
      "description": "Endpoints for the Ambient AI listening system. Handles audio upload-and-process pipeline (transcription → insight extraction → schedule extraction → RAG indexing) and fetching processed results.",
      "item": [
        {
          "name": "Process Ambient Audio",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Main ambient pipeline endpoint. Accepts an audio file (WebM / WAV / MP3 / MP4) + a date string.\n\nPipeline:\n1. FFmpeg normalization (16kHz, mono WAV)\n2. Speaker diarization via HuggingFace API\n3. Audio assembly (per-speaker chunks)\n4. Groq Whisper transcription\n5. RAG ingestion (/upload-text)\n6. Insight + schedule extraction via Llama-3.3-70b\n7. MongoDB save (Insight, Schedule, Analytics models)\n\nBody: multipart/form-data with 'audio' (file) + 'date' (YYYY-MM-DD string).\nReturns: { success, message, transcript, data: { insights, schedules } }",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "audio",
                  "type": "file",
                  "src": "",
                  "description": "Ambient audio file — WebM, WAV, MP3, or MP4. Minimum 1KB to avoid empty chunk rejection."
                },
                {
                  "key": "date",
                  "value": "{{today}}",
                  "type": "text",
                  "description": "Date associated with this audio chunk in YYYY-MM-DD format."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/analytics/process-audio",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "process-audio"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has transcript', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json).to.have.property('transcript');",
                  "    pm.expect(json).to.have.property('data');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get Analytics (All / By Date)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Returns all Analytics documents for the user (each populated with insights + schedules). Optionally filter by date using ?date=YYYY-MM-DD query param. Used by Insights.jsx page.",
            "url": {
              "raw": "{{base_url}}/api/analytics?date={{today}}",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics"],
              "query": [
                {
                  "key": "date",
                  "value": "{{today}}",
                  "description": "Optional — filter analytics to a specific YYYY-MM-DD date. Remove to get all dates."
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has analytics array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.analytics).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Get All Schedules",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "description": "Returns all Schedule documents for the authenticated user, sorted by date ascending. Used by Schedules.jsx page to populate the task list.",
            "url": {
              "raw": "{{base_url}}/api/analytics/schedules",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "schedules"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has schedules array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.schedules).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    }
  ]
}
