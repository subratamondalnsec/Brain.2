            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": "",
                  "description": "Select any image file (.jpg, .png, .webp etc.)"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/upload/image",
              "host": ["{{base_url}}"],
              "path": ["api", "upload", "image"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json && json.imageUrl) {",
                  "    pm.collectionVariables.set('uploadedImageUrl', json.imageUrl);",
                  "    console.log('Image URL saved:', json.imageUrl);",
                  "}"
                ]
              }
            }
          ],
          "response": []
